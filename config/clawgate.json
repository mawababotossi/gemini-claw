{
    "project": {
        "name": "ClawGate",
        "description": "Superviseur d'agents IA via ACP",
        "defaultModel": "gemini-2.0-flash"
    },
    "providers": [
        {
            "name": "google",
            "type": "google",
            "apiKey": "${GEMINI_API_KEY}",
            "models": [
                "gemini-3-1-pro-preview",
                "gemini-3-flash-preview",
                "gemini-2.0-flash",
                "gemini-1.5-pro",
                "gemini-1.5-flash"
            ]
        },
        {
            "name": "openclaw",
            "type": "custom",
            "baseUrl": "${OPENCLAW_API_BASE}",
            "models": [
                "together/moonshotai/Kimi-K2.5"
            ]
        }
    ],
    "agents": [
        {
            "name": "main",
            "model": "gemini-3-flash-preview",
            "modelCallback": "gemini-3-1-pro-preview",
            "fallbackModels": [
                "gemini-1.5-pro"
            ],
            "heartbeat": {
                "enabled": true,
                "intervalMinutes": 60
            },
            "mcpServers": [
                {
                    "name": "clawgate-skills",
                    "type": "sse",
                    "url": "http://localhost:3002/api/mcp/messages",
                    "headers": []
                }
            ],
            "allowedPermissions": [
                "google_web_search",
                "shell",
                "terminal",
                "updateMemoryFile",
                "delegate_task",
                "schedule_task",
                "list_tasks",
                "remove_task",
                "list_agents",
                "read_file",
                "write_file",
                "run_shell_command",
                "network",
                "read_skill",
                "run_code",
                "getCurrentTime"
            ],
            "status": "Healthy",
            "skills": [
                "nano-pdf",
                "skill-creator",
                "weather",
                "markdown-to-pdf",
                "clawhub"
            ]
        },
        {
            "name": "scipro",
            "model": "gemini-3-1-pro-preview",
            "modelCallback": "gemini-3-flash-preview",
            "heartbeat": {
                "enabled": true,
                "intervalMinutes": 120
            },
            "mcpServers": [
                {
                    "name": "clawgate-skills",
                    "type": "sse",
                    "url": "http://localhost:3002/api/mcp/messages",
                    "headers": []
                }
            ],
            "allowedPermissions": [
                "getCurrentTime",
                "google_web_search",
                "shell"
            ],
            "status": "Healthy"
        },
        {
            "name": "viral-writer",
            "model": "gemini-3-flash-preview",
            "heartbeat": {
                "enabled": false
            },
            "mcpServers": [
                {
                    "name": "clawgate-skills",
                    "type": "sse",
                    "url": "http://localhost:3002/api/mcp/messages",
                    "headers": []
                }
            ],
            "allowedPermissions": [
                "getCurrentTime",
                "google_web_search",
                "shell"
            ],
            "status": "Healthy"
        }
    ],
    "channels": {
        "webchat": {
            "enabled": true,
            "port": 3001,
            "agent": "main"
        },
        "whatsapp": {
            "enabled": true,
            "agent": "main",
            "mentionOnly": false,
            "phoneNumber": "22898111917",
            "allowList": [
                "22898111917"
            ]
        }
    },
    "cron": [
        {
            "cron": "0 8 * * *",
            "agentName": "main",
            "delivery": "whatsapp -> 22898111917",
            "prompt": "Fais moi un rapport complet sur l'état de mes finances et de mes projets en cours. Analyse mes derniers messages et résume les points importants avant que je ne commence ma journée."
        }
    ]
}