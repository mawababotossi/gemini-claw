{
  "name": "gemini-claw",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted AI agent gateway powered by gemini-cli — OpenClaw-inspired",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm --filter '@geminiclaw/*' run build",
    "dev": "pnpm -r run dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "pnpm": {
    "neverBuiltDependencies": [
      "node-pty",
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "@types/inquirer": "^9.0.9",
    "commander": "^14.0.3",
    "inquirer": "^13.3.0"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0"
  }
}