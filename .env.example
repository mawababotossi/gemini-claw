# Environment variables for GeminiClaw
# Copy to .env and fill in your values

# ─── Auth (choose one) ───────────────────────────────
# Option A: OAuth Google (free tier, 1000 req/day) — RECOMMANDÉ
GOOGLE_GENAI_USE_GCA=true

# GEMINI_API_KEY=your_key_here

# Option C: Anthropic API Key (for Claude Code)
# ANTHROPIC_API_KEY=your_key_here

# Option D: OpenAI API Key (for Codex CLI)
# OPENAI_API_KEY=your_key_here

# ─── Channels ─────────────────────────────────────────
# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# WebChat port
WEBCHAT_PORT=3001

# [IMPORTANT] Authentication tokens
# GEMINICLAW_API_TOKEN is used for REST API protection.
# DASHBOARD_SECRET is used for WebSocket identification.
GEMINICLAW_API_TOKEN=
DASHBOARD_SECRET=
VITE_API_TOKEN=

# [OPTIONAL] Restrict CORS to a specific origin (default: http://localhost:5173).
DASHBOARD_ORIGIN=http://localhost:5173

# ─── Webhooks (optional) ──────────────────────────────
# WEBHOOK_SECRET=your_webhook_token

# ─── Data directory ───────────────────────────────────
DATA_DIR=./data
