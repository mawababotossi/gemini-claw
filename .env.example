# Environment variables for GeminiClaw
# Copy to .env and fill in your values

# ─── Auth (choose one) ───────────────────────────────
# Option A: OAuth Google (free tier, 1000 req/day) — RECOMMANDÉ
GOOGLE_GENAI_USE_GCA=true

# Option B: Gemini API Key (from aistudio.google.com) — déscommenter si préféré
# GEMINI_API_KEY=your_key_here

# ─── Channels ─────────────────────────────────────────
# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# WebChat port
WEBCHAT_PORT=3001

# ─── Gateway ──────────────────────────────────────────
GATEWAY_PORT=3000

# [IMPORTANT] DASHBOARD_SECRET must be a long random string.
# Use this to protect the Gateway API and identify the WebChat Owner.
DASHBOARD_SECRET=

# [OPTIONAL] Restrict CORS to a specific origin (default: http://localhost:5173).
DASHBOARD_ORIGIN=http://localhost:5173

# ─── Webhooks (optional) ──────────────────────────────
# WEBHOOK_SECRET=your_webhook_token

# ─── Data directory ───────────────────────────────────
DATA_DIR=./data
